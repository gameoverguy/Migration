generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model categories {
  id       Int        @id @default(autoincrement())
  name     String?    @unique(map: "name_uniq_pg_1") @db.VarChar(100)
  products products[]
}

model logs {
  id         Int       @id @default(autoincrement())
  level      String?   @db.VarChar(20)
  message    String?   @db.Text
  data       Bytes?    @db.ByteA
  created_at DateTime? @default(now())
}

model order_items {
  order_id   Int
  product_id Int
  quantity   Int?
  price      Decimal? @db.Decimal(10, 2)
  orders     orders   @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "order_items_ibfk_1")
  products   products @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "order_items_ibfk_2")

  @@id([order_id, product_id])
  @@index([product_id], map: "product_id_idx_pg_1")
}

model orders {
  id           Int            @id @default(autoincrement())
  user_id      Int?
  status       orders_status?
  total_amount Decimal?       @db.Decimal(12, 2)
  created_at   DateTime?      @default(now())
  order_items  order_items[]
  users        users?         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "orders_ibfk_1")

  @@index([user_id], map: "user_id_idx_pg_2")
}

model product_tags {
  product_id Int
  tag_id     Int
  products   products @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "product_tags_ibfk_1")
  tags       tags     @relation(fields: [tag_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "product_tags_ibfk_2")

  @@id([product_id, tag_id])
  @@index([tag_id], map: "tag_id_idx_pg_3")
}

model products {
  id           Int            @id @default(autoincrement())
  name         String?        @db.VarChar(150)
  description  String?        @db.Text
  price        Decimal?       @db.Decimal(10, 2)
  stock        Int?
  category_id  Int?
  created_at   DateTime?      
  order_items  order_items[]
  product_tags product_tags[]
  categories   categories?    @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "products_ibfk_1")

  @@index([category_id], map: "idx_products_category_idx_pg_4")
}

model profiles {
  id         Int     @id @default(autoincrement())
  user_id    Int?    @unique(map: "user_id_uniq_pg_2")
  bio        String? @db.Text
  avatar_url String? @db.VarChar(255)
  users      users?  @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "profiles_ibfk_1")
}

model tags {
  id           Int            @id @default(autoincrement())
  name         String?        @unique(map: "name_uniq_pg_3") @db.VarChar(50)
  product_tags product_tags[]
}

model users {
  id         Int       @id @default(autoincrement())
  name       String?   @db.VarChar(100)
  email      String?   @unique(map: "email_uniq_pg_4") @db.VarChar(150)
  age        Int?
  is_active  Boolean?  @default(true)
  metadata   Json?
  created_at DateTime? @default(now())
  orders     orders[]
  profiles   profiles?

  @@index([email], map: "idx_users_email_idx_pg_5")
}

enum orders_status {
  pending
  paid
  shipped
  cancelled
}
